# Supabase（必填）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 伺服器專用（必填，切勿加 NEXT_PUBLIC_ 前綴，勿提交至 Git）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LINE Messaging API（必填，部署 LINE 功能時）
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
NEXT_PUBLIC_LIFF_ID=

# 部署後的 HTTPS 網址（Vercel 給的網域，例如 https://xxx.vercel.app）
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# 首次建立管理員（僅執行 setup-admin-auth.mjs 時使用，勿提交）
# ADMIN_EMAIL=admin@your-clinic.com
# ADMIN_PASSWORD=
